# --- Kafka Configuration ---

# The address of the Kafka broker.
# IMPORTANT: 
# - Use 'kafka:29092' when running code INSIDE the Docker container.
# - Use 'localhost:9092' when running code LOCALLY on your machine.
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
CHAT_TOPIC=user-messages # The name of the Kafka topic used for chat messages.

# --- Consumer Configuration ---

# The ID for the consumer group. 
# Consumers with the same GROUP_ID will share the load of a topic.
GROUP_ID=chat-consumer-group

# --- Logging (Optional but recommended) ---
LOG_LEVEL=INFO # Set to DEBUG, INFO, WARNING, ERROR