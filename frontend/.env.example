# Frontend Configuration
# Copy this file to .env and adjust values as needed.

# Default username shown on the login page placeholder
VITE_DEFAULT_USERNAME=Daria

# Topics the user is pre-subscribed to (comma-separated)
VITE_SUBSCRIBED_TOPICS=engineering,release_ops,product-updates

# Mock online users (comma-separated usernames)
VITE_ONLINE_USERS=Ava,Noah,Lena,Mateo,Daria

# Mock message count (how many initial messages to load)
VITE_MOCK_MESSAGE_COUNT=4
